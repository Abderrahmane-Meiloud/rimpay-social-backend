APP_NAME="RIMPay Social Backend"
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

DATABASE_URL="postgresql://username:password@localhost:5432/rimpay_social?schema=public"

JWT_SECRET="replace_with_a_strong_secret"
JWT_EXPIRES_IN="1d"

ALLOW_PROD_SEED=false

# Required when NODE_ENV=production. Connection URL for the Redis
# instance backing auth login/refresh rate limiting. Startup fails if
# absent, unreachable, or if Redis-backed storage cannot initialize.
# Not used and not required in development or test.
# THROTTLE_REDIS_URL="redis://:password@your-redis-host:6379"

# Number of trusted reverse-proxy hops in front of this app (Express
# "trust proxy" setting). Only set this to the exact hop count of your
# deployment's trusted load balancer/reverse proxy chain so that
# X-Forwarded-For is honored only from those hops. Leave unset if there
# is no trusted reverse proxy in front of this app.
# TRUST_PROXY_HOPS=1

# Required explicit confirmation to run "npm run seed:fixed-accounts". The
# seed always refuses to run when NODE_ENV=production, and also refuses
# unless this is set to exactly "true". Creates/updates exactly three fixed
# local accounts (admin@taazor.mr, program@taazor.mr, operator@taazor.mr),
# one per institutional web role. Passwords are read only from the env vars
# below and are NEVER printed; only email/role/created-or-updated status is
# logged.
# DEMO_FIXED_ACCOUNTS=true
DEMO_ADMIN_PASSWORD=change-me-locally
DEMO_PROGRAMME_PASSWORD=change-me-locally
DEMO_OPERATOR_PASSWORD=change-me-locally
