# Test environment variables — PLACEHOLDERS ONLY
# These must be set as environment variables before running tests.
# The test runner (scripts/run-e2e.ts) derives them from backend/.env for local use.
# In CI, set these directly as environment variables.
# Never create a .env.test file.

# DATABASE_URL_TEST="postgresql://user:password@localhost:5432/rimpay_social_test?schema=public"
# JWT_SECRET="test-only-jwt-secret-not-for-production"
# JWT_EXPIRES_IN="15m"
# NODE_ENV="test"
